// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// TABEL KARTU KELUARGA
model KartuKeluarga {
  id             Int     @id @default(autoincrement())
  nomorKK        String  @unique // Harus UNIQUE sebagai kunci identitas KK dari berbagai HP
  kepalaKeluarga String
  alamatLengkap  String?
  nomorRT        String?
  nomorRW        String?
  dusun          String?
  desa           String?
  kecamatan      String?
  latitude       String?
  longitude      String?

  // --- KOLOM PELACAKAN (AUDIT) ---
  diinputOleh    String?   // Menyimpan Nama/Email Kader yang pertama kali input
  createdAt      DateTime  @default(now()) // Otomatis catat waktu dibuat
 updatedAt      DateTime  @updatedAt @default(now())      // Otomatis catat waktu terakhir diedit

  // Relasi: 1 KK punya banyak Warga
  Warga          Warga[]
}

// TABEL WARGA
model Warga {
  id               Int     @id @default(autoincrement())
  nik              String  @unique // Harus UNIQUE sebagai kunci identitas Warga
  nomorRekamMedis  String?
  nama             String
  tanggalLahir     String?
  jenisKelamin     String?
  golonganDarah    String?
  statusKeluarga   String?
  pekerjaan        String?
  pendidikan       String?
  noHp             String?
  statusPernikahan String?
  statusKehamilan  String?
  noBPJS           String?
  alergi           String?
  riwayatPenyakit  String?
  disabilitas      String?
  catatanKhusus    String?

  // --- KOLOM PELACAKAN (AUDIT) ---
  diinputOleh      String?   // Menyimpan Nama/Email Kader yang pertama kali input
  createdAt        DateTime  @default(now()) // Otomatis catat waktu dibuat
 updatedAt      DateTime  @updatedAt @default(now())     // Otomatis catat waktu terakhir diedit

  // Relasi ke tabel KartuKeluarga
  nomorKkRel       String
  KartuKeluarga    KartuKeluarga @relation(fields: [nomorKkRel], references: [nomorKK], onDelete: Cascade)
}

model User {
  id           Int      @id @default(autoincrement())
  namaLengkap  String
  email        String   @unique
  nomorTelepon String
  wilayahKerja String
  jabatan      String
  password     String
  fotoProfil   String?  
  
  createdAt    DateTime @default(now())
 updatedAt      DateTime  @updatedAt @default(now()) // Tambahan agar tahu kapan user ini update profil
}